{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vite/client", "node", "@cloudflare/workers-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@/server/*": ["./server/*"],
      "@/lib/*": ["./lib/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "server/**/*.ts",
    "functions/**/*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "drizzle.config.ts"
  ],
  "exclude": ["node_modules", "dist", ".wrangler", ".dev"]
}
