# Nuansu — client-bundle environment template.
# Copy this file to `apps/web/.env.local` and fill in real values where needed.
# `apps/web/.env.local` is git-ignored.
#
# This file holds ONLY browser-bundle env (VITE_PUBLIC_*). Vite reads it from
# the project tree because that's the only path its loader supports. These
# values ship to the browser as static strings — by definition they are public.
#
# Server secrets live OUTSIDE the project tree. See `.env.example` at the repo
# root for the server-side template, which the loader (scripts/load-env.mjs)
# resolves from `~/.local/share/nuansu/.env` first.
#
# NEVER put server secrets in this file.

VITE_PUBLIC_APP_URL=http://localhost:5173

# Optional. Client-side captcha site key (paired with TURNSTILE_SECRET_KEY on
# the server). Site keys are public by design.
VITE_PUBLIC_TURNSTILE_SITE_KEY=

# Optional. PostHog client-side ingest key. Same project key the server uses,
# but exposed to the bundle for browser-emitted events.
VITE_PUBLIC_POSTHOG_KEY=

# Optional. Sentry browser-SDK DSN. Browser DSNs are public by design.
VITE_PUBLIC_SENTRY_DSN=
