{
  "name": "nuansu",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/with-env.mjs -- pnpm --filter @nuansu/web dev",
    "predev": "node scripts/sync-wrangler-vars.mjs",
    "build": "node scripts/with-env.mjs -- pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node scripts/with-env.mjs -- vitest run",
    "test:watch": "node scripts/with-env.mjs -- vitest",
    "test:e2e": "node scripts/with-env.mjs -- pnpm --filter @nuansu/web test:e2e",
    "pretest:e2e": "node scripts/sync-wrangler-vars.mjs",
    "bench": "node scripts/with-env.mjs -- vitest bench --run",
    "db:migrate": "node scripts/with-env.mjs -- pnpm --filter @nuansu/web db:migrate",
    "db:seed": "node scripts/with-env.mjs -- pnpm --filter @nuansu/web db:seed",
    "sync-env": "node scripts/sync-wrangler-vars.mjs",
    "ladle": "pnpm --filter @nuansu/web ladle",
    "lighthouse": "pnpm --filter @nuansu/web lighthouse",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "fast-check": "^4.7.0",
    "globals": "^17.6.0",
    "lefthook": "^1.10.4",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.5"
  }
}
