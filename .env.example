# Nuansu — server-side environment template.
#
# Copy this file to `~/.local/share/nuansu/.env` (XDG canonical):
#
#   mkdir -p ~/.local/share/nuansu
#   cp .env.example ~/.local/share/nuansu/.env
#   chmod 600 ~/.local/share/nuansu/.env
#
# The loader (`scripts/load-env.mjs`) resolves env in this order:
#   1. $NUANSU_ENV_FILE          — explicit override
#   2. $XDG_DATA_HOME/nuansu/.env
#   3. ~/.local/share/nuansu/.env
#   4. ./.env.local              — repo-root fallback (fresh clone, CI)
#   5. ./.env                    — last resort
#
# Browser-bundle env (VITE_PUBLIC_*) is NOT here — Vite reads it directly from
# `apps/web/.env.local`. See `apps/web/.env.example`.
#
# Marker convention:
#   STUB    — a working stub default exists; only replace if you want the real service.
#   REQUIRED— must be set for the app to boot or for the feature to work.
#   OPTIONAL— feature is hidden if missing.

# ─────────────────────────── General ───────────────────────────
NODE_ENV=development
APP_URL=http://localhost:5173
APP_ENV=local                    # local | preview | production
DEFAULT_LOCALE=en                # en | ja
LOG_LEVEL=info

# ─────────────────────────── Database (Postgres) ───────────────────────────
# Matches docker-compose.yml defaults.
DATABASE_URL=postgres://nuansu:nuansu_dev@localhost:5432/nuansu
DIRECT_DATABASE_URL=postgres://nuansu:nuansu_dev@localhost:5432/nuansu

# ─────────────────────────── Redis (rate-limit + cache) ───────────────────────────
# Local Docker Redis. In prod this is Upstash REST endpoint + token.
UPSTASH_REDIS_REST_URL=http://localhost:6379
UPSTASH_REDIS_REST_TOKEN=local_dev_token

# ─────────────────────────── Better Auth ───────────────────────────
# Generate with: openssl rand -hex 32
# REQUIRED
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# ─────────────────────────── OAuth providers (OPTIONAL in dev) ───────────────────────────
# Magic-link sign-in works without these. Each provider's button is hidden if
# its CLIENT_ID is missing.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# ─────────────────────────── Anthropic (LLM) ───────────────────────────
# REQUIRED for real translation. Without it, LLM_PROVIDER auto-falls-back to "stub"
# (canned responses replayed from fixtures). Tests run on the stub regardless.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-6
ANTHROPIC_MODEL_BUDGET=claude-haiku-4-5
LLM_PROVIDER=auto                # auto | anthropic | stub

# ─────────────────────────── Stripe (STUB in dev) ───────────────────────────
# Stub mode default. Set STRIPE_PROVIDER=stripe to use real Stripe (test or live).
STRIPE_PROVIDER=stub             # stub | stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# ─────────────────────────── Email (STUB in dev) ───────────────────────────
# Stub mode default. In dev, mailcrab catches outgoing email; open http://localhost:1080.
EMAIL_PROVIDER=mailcrab          # mailcrab | resend | stub
RESEND_API_KEY=
RESEND_FROM_ADDRESS=Nuansu <hello@nuansu.app>
RESEND_FROM_ADDRESS_JP=Nuansu <hello-jp@nuansu.app>
SMTP_HOST=localhost
SMTP_PORT=1025

# ─────────────────────────── Object storage (MinIO in dev) ───────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_ACCESS_KEY_ID=nuansu
S3_SECRET_ACCESS_KEY=nuansu_dev_secret
S3_BUCKET=nuansu-avatars
S3_FORCE_PATH_STYLE=true

# ─────────────────────────── Encryption (STUB in dev) ───────────────────────────
# Stub mode uses a fixed local KMS key derived from KMS_LOCAL_SEED. Change the seed
# to invalidate all locally-encrypted data.
KMS_PROVIDER=stub                # stub | aws
KMS_LOCAL_SEED=local-dev-only-do-not-use-in-prod
KMS_KEY_ID=
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────── Captcha (OPTIONAL in dev) ───────────────────────────
# Captcha is bypassed in dev unless TURNSTILE_SECRET_KEY is set. The matching
# site key (TURNSTILE_SITE_KEY → VITE_PUBLIC_TURNSTILE_SITE_KEY) lives in
# apps/web/.env.local; it's public by design.
TURNSTILE_SECRET_KEY=

# ─────────────────────────── Observability (OPTIONAL in dev) ───────────────────────────
# Server-side ingest. The matching browser DSN/key (VITE_PUBLIC_*) lives in
# apps/web/.env.local; those are public by design.
SENTRY_AUTH_TOKEN=
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com

# ─────────────────────────── Feature flags / safety ───────────────────────────
LLM_KILL_SWITCH=false
LLM_FREE_TIER_DOWNGRADE=false
DAILY_FREE_QUOTA=10
MAX_DAILY_USER_USD=2.00
TRIAL_DAYS=14
